# ==========================================
# Chinese Culture Studio — Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored.
# Production: set these in Render dashboard → Environment.

# --- Database ---
# Local dev: SQLite (file:./dev.db)
# Production: Neon PostgreSQL (set in Render dashboard)
DATABASE_URL="file:./dev.db"

# --- PayPal Payment (Standard Checkout) ---
# Get Live credentials from https://www.paypal.com/businessmanage/account/websettings
# Sandbox: set PAYPAL_SANDBOX=true, get sandbox credentials from https://developer.paypal.com
PAYPAL_SANDBOX=true
PAYPAL_EMAIL="your-paypal-email@example.com"
PAYPAL_PDT_TOKEN=""         # PayPal Payment Data Transfer token (for success page verification)

# --- App URL ---
# Local dev: http://localhost:3000
# Production: https://www.culture-of-china.com (set in Render dashboard)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin ---
# Token for accessing /admin dashboard and /api/report
ADMIN_TOKEN="change-me-to-a-random-string"

# --- OpenRouter AI ---
# Used by: palm-reading, dream-interpretation
# Get key from https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# --- Telegram Bot (optional) ---
# Get TELEGRAM_BOT_TOKEN from @BotFather on Telegram
# TELEGRAM_CHAT_ID is the target channel/group ID (e.g. @yourchannel or -100xxx)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_POST_SECRET=""

# --- Resend Email (optional) ---
# Get key from https://resend.com/api-keys (free tier: 100 emails/day)
# CONTACT_EMAIL is where contact form messages and daily digests are sent
RESEND_API_KEY=""
CONTACT_EMAIL=""

# --- Cron Job Secret (optional) ---
# Used by /api/cron and GitHub Actions daily-seo workflow
# Falls back to ADMIN_TOKEN if not set
CRON_SECRET=""
