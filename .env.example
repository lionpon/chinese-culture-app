# ==========================================
# Chinese Culture Studio — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# Local dev uses .env.local (gitignored).
# Vercel: set these in Settings → Environment Variables.

# --- Database (PostgreSQL for production) ---
# Local dev: SQLite file path
# Production: Neon PostgreSQL connection string
#   postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="file:./dev.db"

# --- Lemon Squeezy Payment ---
# Get these from https://app.lemonsqueezy.com/settings/api
# Test keys: ls_test_xxx  or  ey_test_xxx
# Live keys: ls_live_xxx  or  ey_live_xxx
LEMON_SQUEEZY_API_KEY="ey_test_xxxxxxxxxxxxxxxx"
LEMON_SQUEEZY_WEBHOOK_SECRET="your-webhook-signing-secret"
LEMON_SQUEEZY_STORE_ID="1"
LEMON_SQUEEZY_VARIANT_ID="1"

# --- App URL ---
# Local dev: http://localhost:3000
# Production: your custom domain (e.g. https://chineseculture.studio)
# Leave empty to auto-detect from Vercel deployment URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin ---
# Token for accessing /admin dashboard and /api/report
ADMIN_TOKEN="change-me-to-a-random-string"

# --- Telegram Bot (optional) ---
# Get TELEGRAM_BOT_TOKEN from @BotFather on Telegram
# TELEGRAM_CHAT_ID is the target channel/group ID (e.g. @yourchannel or -100xxx)
# If configured, the bot can post daily hexagrams automatically
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Telegram Auto-Post Secret ---
# Set this to enable automatic Telegram posting from /api/cron and AutoDailyReport
# Must be a random string — passed as ?token= query param to /api/telegram-post
TELEGRAM_POST_SECRET=""

# --- Resend Email (optional) ---
# Get your API key from https://resend.com/api-keys (free tier: 100 emails/day)
# CONTACT_EMAIL is where contact form messages and daily digests are sent
RESEND_API_KEY=""
CONTACT_EMAIL=""

# --- Cron Job Secret (optional) ---
# Used to authenticate /api/cron requests (e.g. from GitHub Actions daily-seo)
# Falls back to ADMIN_TOKEN if not set
CRON_SECRET=""
